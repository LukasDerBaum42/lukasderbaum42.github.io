package templates

templ Page(title string, body string) {
<!doctype html>
<html>
<head>
    <meta charset="utf-8"/>
    <title>{ title }</title>
    <link rel="stylesheet" href="style/style.css">
</head>
<body>
    <h1>{ title }</h1>
    <div>
    
        @templ.Raw(body)
        
    </div>
</body>
</html>
}